            <div class="comic-panel-number">#7.0</div>

            <div class="speech-bubble">
              <div class="speech-tail"></div>
              <p>Po přesně třiceti dnech se vrátil.</p>
            </div>
          </div>
          <div class="comic-panel panel-tall" data-i="7" data-sentence="1">
            <img src="img/screenshots/01_08_01_s0.jpg" alt="Díl 1, Odst. 8, Věta 2" class="comic-panel-img" loading="lazy">
            <div class="comic-panel-overlay"></div>
