            </div>
          </div>
          <div class="comic-panel panel-normal" data-i="1" data-sentence="0">
            <img src="img/screenshots/01_02_01.jpg" alt="Díl 1, Odst. 2, Věta 1" class="comic-panel-img" loading="lazy">
