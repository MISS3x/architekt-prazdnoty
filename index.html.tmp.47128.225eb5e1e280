            <div class="comic-panel-number">#33.4</div>

            <div class="speech-bubble">
              <div class="speech-tail"></div>
              <p>Mají nanovlákna.</p>
            </div>
          </div>
          <div class="comic-panel panel-wide" data-i="33" data-sentence="5">
