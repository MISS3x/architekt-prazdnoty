            <div class="comic-panel-number">#4.0</div>

            <div class="speech-bubble">
              <div class="speech-tail"></div>
              <p>„Odpojuji neuro-link.</p>
            </div>
          </div>
          <div class="comic-panel panel-normal" data-i="4" data-sentence="1">
            <img src="img/screenshots/01_05_01_s0.jpg" alt="Díl 1, Odst. 5, Věta 2" class="comic-panel-img" loading="lazy">
