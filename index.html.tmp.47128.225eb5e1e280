            <div class="comic-panel-overlay"></div>
            <div class="comic-panel-border"></div>
            <div class="comic-panel-number">#6.6</div>

            <div class="speech-bubble">
              <div class="speech-tail"></div>
              <p>Tyto vzorce pak promítal do organických křivek svých mrakodrapů.</p>
            </div>
          </div>
          <div class="comic-panel panel-wide" data-i="6" data-sentence="7">
            <img src="img/screenshots/01_07_02_s7.jpg" alt="Díl 1, Odst. 7, Věta 8" class="comic-panel-img" loading="lazy">
